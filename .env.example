# Environment Variables - COPY TO .env AND CHANGE VALUES

# Database
DATABASE_URL=postgresql://postgres:CHANGE_THIS_PASSWORD@db:5432/announcement_db?schema=public

# NextAuth - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_THIS_SECRET
NEXTAUTH_URL=http://localhost:3100

# Scheduler Security - Generate with: openssl rand -hex 16
CRON_SECRET=CHANGE_THIS_SECRET

# Auto Update (optional)
ENABLE_AUTO_UPDATE=true

# ===== PORTAL SSO =====
# Generate with: openssl rand -hex 32
# WAJIB. 64 hex chars (32 byte) untuk AES-256-GCM encrypt kredensial app.
PORTAL_CREDENTIAL_KEY=CHANGE_THIS_KEY

# ===== AUDIT TRAIL =====
# Retensi audit log dalam hari. 0 = simpan selamanya. Default: 365
AUDIT_RETENTION_DAYS=365

# ===== PORTAL SESSION (opsional) =====
# Max age sesi portal dalam detik. Default: 43200 (12 jam)
PORTAL_SESSION_MAX_AGE=43200
